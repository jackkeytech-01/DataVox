/*
Adding to store
*/
async function AddStore() {
  const res = await fetch('/account/addStore', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ name, qn, running_out, unitPrice, unitFrom, sellingPrice })
  })
  const data = await res.json();
  if (data.problem) {
    showMSG(data.problem, data.message);
    send_btn.disabled=false;
    send_btn.value='Add Product';
    return;
  }
  
  send_btn.disabled=false;
  send_btn.value='Add Product';
  form.reset();
}




async function updateRecord(id_) {
  const res = await fetch(`/store/${id_}`, {
    method: 'PUT',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ name, qn, running_out, unitPrice, unitFrom, sellingPrice })
  });
  const data = await res.json();
if (data.problem) {
send_btn.disabled = false;
}
else {
  displayForm('', false);
  window.location.href = '/account/store';
  flyMSG('Product Edited Successfully')
}
  showMSG(data.problem, data.message);
}




