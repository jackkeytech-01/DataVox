<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DataVox - Sub Stores</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5f7fa;
    padding:20px;
}

.container{
    max-width:900px;
    margin:auto;
}

.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:25px;
}

.page-header h1{
    color:#333;
}

.add-btn{
    background:#2563eb;
    color:white;
    border:none;
    padding:12px 18px;
    border-radius:10px;
    cursor:pointer;
    font-size:15px;
    font-weight:bold;
}

.add-btn:hover{
    opacity:0.9;
}

.empty-state{
    text-align:center;
    background:white;
    padding:60px 20px;
    border-radius:15px;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.empty-state i{
    font-size:60px;
    color:#bdbdbd;
    margin-bottom:15px;
}

.empty-state h2{
    color:#555;
    margin-bottom:10px;
}

.empty-state p{
    color:#888;
}

.substores{
    display:grid;
    gap:15px;
}

.store-card{
    background:white;
    padding:18px;
    border-radius:15px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.store-info{
    display:flex;
    align-items:center;
    gap:15px;
}

.store-icon{
    width:50px;
    height:50px;
    border-radius:12px;
    background:#eef4ff;
    color:#2563eb;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:22px;
}

.store-name{
    font-size:18px;
    font-weight:600;
    color:#333;
}

.store-actions{
    display:flex;
    gap:10px;
}

.action-btn{
    border:none;
    padding:10px 14px;
    border-radius:8px;
    cursor:pointer;
}

.view-btn{
    background:#22c55e;
    color:white;
}

.delete-btn{
    background:#ef4444;
    color:white;
}

@media(max-width:700px){

.store-card{
    flex-direction:column;
    align-items:flex-start;
    gap:15px;
}

.store-actions{
    width:100%;
}

.action-btn{
    flex:1;
}
}
</style>
</head>
<body>

<div class="container">

    <div class="page-header">
        <h1>Sub Stores</h1>

        <button class="add-btn" id="addStoreBtn">
            <i class="fa-solid fa-plus"></i>
            Add Sub Store
        </button>
    </div>

    <!-- Empty Message -->
     <% if (user.sub_store) {%>
<% if (user.sub_store.length<=0) {%>
    <div class="empty-state" id="emptyState">
        <i class="fa-solid fa-shop"></i>
        <h2>No Sub Stores Yet</h2>
        <p>Create your first sub store to start managing inventory.</p>
    </div>
<%} else {%>
    <!-- Stores List -->
    <div class="substores" id="storesContainer"></div>

</div>
<%}} else {%>
    <div class="empty-state" id="emptyState">
        <i class="fa-solid fa-shop"></i>
        <h2>No Sub Stores Yet</h2>
        <p>Create your first sub store to start managing inventory.</p>
    </div>
    <%}%>
<script>

let subStores = [];

const storesContainer = document.getElementById("storesContainer");
const emptyState = document.getElementById("emptyState");

function renderStores(){

    storesContainer.innerHTML = "";

    if(subStores.length === 0){
        emptyState.style.display = "block";
        return;
    }

    emptyState.style.display = "none";

    subStores.forEach((store,index)=>{

        const card = document.createElement("div");
        card.className = "store-card";

        card.innerHTML = `
            <div class="store-info">
                <div class="store-icon">
                    <i class="fa-solid fa-store"></i>
                </div>

                <div>
                    <div class="store-name">${store}</div>
                </div>
            </div>

            <div class="store-actions">

                <button class="action-btn view-btn">
                    <i class="fa-solid fa-eye"></i>
                    Open
                </button>

                <button class="action-btn delete-btn"
                        onclick="deleteStore(${index})">
                    <i class="fa-solid fa-trash"></i>
                    Delete
                </button>

            </div>
        `;

        storesContainer.appendChild(card);
    });
}

function deleteStore(index){

    if(confirm("Delete this sub store?")){
        subStores.splice(index,1);
        renderStores();
    }
}

document.getElementById("addStoreBtn")
.addEventListener("click",()=>{

    const name = prompt("Enter Sub Store Name");

    if(name && name.trim() !== ""){
        subStores.push(name.trim());
        renderStores();
    }

});

renderStores();

</script>

</body>
</html>
