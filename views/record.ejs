            <input type="number"
            placeholder="e.g. 20000" id="Edittotal" name="total" required/>

        </div>

        <div class="input-group">

            <label>
                Time
            </label>

            <div class="time-wrapper">

                <input type="text" readonly=true id="Editclock" name="time" required/>

                <i class="fa-regular fa-clock"></i>

