<script type="text/javascript" defer>
    let edit_sale_form = document.getElementById('edit-sale-form');
    let edit_exp_form = document.getElementById('edit-exp-form');
    showEditExp(false);
    showEditSale(false);
    function showEditSale(opt) {
        if (opt) {
            showEditExp(false);
            edit_sale_form.classList.remove('hide');
        }
        else {
            edit_sale_form.classList.add('hide');
        }
    }
    function showEditExp(opt) {
        if (opt) {
            showEditSale(false);
            edit_exp_form.classList.remove('hide');
        }
        else {
            edit_exp_form.classList.add('hide');
        }
    }
</script>
<script type="text/javascript">
