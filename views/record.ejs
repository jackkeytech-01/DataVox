<script type="text/javascript">
let selector = document.getElementById('productsName');
async function getRecords() {
    try {
const res = await fetch('/account/api/user');
const data = await res.json();
for (var i=0; i<data.names.length; i++) {
    let option = document.createElement('option');
    option.setAttribute('value', `${data.names[i]}`);
    option.innerHTML = data.names[i];
    selector.appendChild(option)
}
}
 catch (err) {
    flyMSG('err' , 'Server Error Occurred.')
 }
}
getRecords();
    async function updateTotal() {
        try {
        const res = await fetch('/account/api/user');
        const data = await res.json();
        let _name = document.getElementById('productsName').value;
        let id_bar = document.getElementById('productsID').value;
        let qn = Number(document.getElementById('qn').value);
        let total = document.getElementById('total');

        if (isNaN(qn)) {
            flyMSG('err', 'Data Input Error. Please try again.');
        }
        else {
            for (var i=0; i<data.store.length; i++) {
                if (
                (data.store[i].name===_name)
                 &&
                (data.store[i].id===id_bar)
                ) 
                {
                    //Get unitFrom qn and chack
                    if (qn>=data.store[i].unitFrom) {
                        let _total = qn*data.store[i].unitPrice;
                        total.value = `${_total}`;
                    }
                    else {
                        let _total = qn*data.store[i].sellingPrice;
                        total.value = `${_total}`;
                    }
                }
            }
        }
    }
    catch (err) {
        console.log(err.message);
    }
    }

    async function updateID() {
        let name_bar = document.getElementById('productsName').value;
        let id_bar = document.getElementById('productsID');
        id_bar.replaceChildren();
        try {
            const _user = await fetch('/account/api/user');
            const data = await _user.json();
            //Get products with similar name to get their ID's
            for (var i=0; i<data.store.length; i++) {
                if (data.store[i].name===name_bar) {
                    let option = document.createElement('option');
                    option.setAttribute('value', `${data.store[i].id}`);   
                    option.innerHTML = data.store[i].id;
                    id_bar.appendChild(option);
                }
            }
        }
        catch (err) {
            console.log(err.message);
        }
    }
</script>


<script type="text/javascript">
let idCarrier = '';
let storeID = '';
let newQN = '';
//Get the main dailyRecord id
function loadID(id) {
    idCarrier = id;
}
    sale_form.addEventListener('submit', async (e)=>{
        try {
        e.preventDefault();
        const name = e.target.name.value.trim();
        const id__ = e.target.id.value;
        const qn = Number(e.target.qn.value);
        const total = Number(e.target.total.value);
        const time = e.target.time.value;

        //First Passing the data to various statements
            //Fetching data from user to get target
            const _user = await fetch('/account/api/user');
            const _record = await _user.json();

        for (var i=0; i<_record.store.length; i++) 
        {
            if (
                    name.toString().toLowerCase()===_record.store[i].name.toString().toLowerCase()
                        &&
                    qn>_record.store[i].qn
                ) {
                flyMSG('err', 'Quantity out of range...');
                }
            if (
                (id__.toString().toLowerCase()===_record.store[i].id.toString().toLowerCase())
                        &&
                    (qn<_record.store[i].qn)
                ) {

                    storeID = _record.store[i]._id.toString();
                    newQN = Number(_record.store[i].qn) - Number(qn);
                    
            }
            }
        const res = await fetch(`/account/records/edit/add/sale`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ storeID, idCarrier, newQN, name, id__,qn, total, time })
                    });
        const data = await res.json();

        if (data.problem) {
            flyMSG('err', data.message);
         }
        else {
            flyMSG('', data.message);
            sale_form.reset;
            location.reload(true);
        }
    } catch (err) {
        console.log(err.message);
        flyMSG('err', 'Server Error occurred. Please try again...');
    }
    });

exp_form.addEventListener('submit', async (e)=>{
    let found = false;
    let exp_sn = 0;
    let record_sn = 0;
        e.preventDefault();
    try {
        const title = e.target.title.value.trim();
        const cost = Number(e.target.cost.value);
        const time = e.target.time.value;
        //alert(`${title} : ${cost} : ${time}`);
        //Checking if the expense was already there
        const user_ = await fetch('/account/api/user');
        const _user = await user_.json();

        const res = await fetch('/account/records/edit/add/exp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idCarrier, title, cost, time })
        })
        const data = await res.json();

        if (data.problem) {
            flyMSG('err', data.message);
        }
        else {
            flyMSG('', data.message);
            exp_form.reset();
            location.reload(true);
        }
    }
    catch (err) {
        console.log(err.message);
        flyMSG('err', 'Server Error Occurred. Please try again.');
    }
});
</script>

<script type="text/javascript">
