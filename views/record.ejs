<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Daily Record</title>

<link rel="stylesheet" href="daily-record.css">
<link rel="icon" type="image/png" href="/image/datavox_icon.png"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
<style>
    *{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}
body{
background:#07192e;
color:white;
}

body{
    min-height:100vh;
    padding-bottom:90px;
}

/* HEADER */

.top-bar{
    height:80px;
    background:#04295f;

    color:white;

    display:flex;
    align-items:center;
    justify-content:space-between;

    padding:0 20px;
}

.top-bar h2{
    font-size:1.05rem;
}

.icon-btn{
    background:none;
    border:none;
    color:white;
    font-size:1.2rem;
    cursor:pointer;
}

/* MAIN */

main{
    padding:20px;
}

/* DATE SELECTOR */

.date-selector{

    display:flex;
    align-items:center;
    justify-content:space-between;

    background:#10253f;

    border-radius:12px;

    padding:12px 15px;

    margin-bottom:18px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);
    color: #fff;
}

.date-selector button{

    background:none;
    border:none;

    cursor:pointer;

    color: transparent;
}

.current-date{

    display:flex;
    align-items:center;
    gap:10px;

    font-weight:600;
}

/* RECORD CARD */

.record-card{

    background:#10253f;

    border-radius:14px;

    overflow:hidden;

    margin-bottom:18px;

    box-shadow:
    0 2px 10px rgba(0,0,0,.08);
}

.sales-title{

    color:#14a44d;

    padding:15px;

    font-size:1rem;

    border-bottom:
    1px solid #eee;
}

.expense-title{

    color:#ff3b30;

    padding:15px;

    font-size:1rem;

    border-bottom:
    1px solid #eee;
}

/* RECORD ITEM */

.record-row{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:15px;

    border-bottom:
    1px solid #f0f0f0;
}

.record-row h4{
    margin-bottom:4px;
}

.record-row small{
    color:#777;
}
.record-details{

    display:flex;

    flex-direction:column;

    gap:4px;
}

.record-details h4{

    margin:0;

    font-size:1rem;
}

.record-details small{

    color:#777;

    font-size:.85rem;
}
.amount{
    font-weight:bold;
    font-size:1rem;
}

.green{
    color:#14a44d;
}

.red{
    color:#ff3b30;
}
.record-lists {
    overflow-y: scroll;
    height: 264px;
    width: 100%;
}
.controls_ {
    width: fit-content;
    margin: 0;
}
.btn {
    margin: 0;
}
.btn.edit {
    background: transparent;
    color: green;
    margin-bottom: 1.5%;
}
.btn.delete {
    background: transparent;
    color: red;
    margin-top: 1.5%;
}
/* TOTALS */

.total-row{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:15px;
}

/* PROFIT */

.profit-card{

    background:#eaf9ee;

    border:2px solid #b8e5c0;

    border-radius:14px;

    padding:18px;

    display:flex;

    justify-content:space-between;

    align-items:center;
}

.profit-card span{

    font-weight:700;

    color:#0f7d3c;
}

.profit-card strong{

    color:#14a44d;

    font-size:2rem;
}


.main_controls {
    position: fixed;
    display: flex;
    flex-direction: column;
    bottom: 15%;
    right: 5%;
    z-index: 9999;
}
.ctrl {
    background: transparent;
    border: none;
    border-radius: 50% 50%;
    width: fit-content !important;
    height: fit-content !important;
    padding: 1% !important;
    font-size: 2em !important;
    font-weight: bolder;
}
.ctrl.sale {
    color: green;
    cursor: pointer;
}
.ctrl.exp {
    color: red;
    cursor: pointer;
}
/* BOTTOM NAV */

.bottom-nav{

    position:fixed;

    bottom:0;
    left:0;

    width:100%;

    background:white;

    display:flex;

    justify-content:space-around;

    padding:12px 0;

    box-shadow:
    0 -3px 10px rgba(0,0,0,.08);
}

.bottom-nav a{

    display:flex;

    flex-direction:column;

    align-items:center;

    gap:5px;

    text-decoration:none;

    color:#888;

    font-size:.8rem;
}

.bottom-nav i{
    font-size:1.1rem;
}

.bottom-nav .active{
    color:#2563eb;
}

/*FORM*/
.container{
    padding:20px;
}

/* FORM CARD */

.form-card{

    background-image: linear-gradient(to right, rgb(0, 128, 0, 0.8), rgb(0, 100, 100), rgb(100, 100, 100) );

    color: white;

    border-radius:15px;

    padding:20px;

    box-shadow:
    0 2px 10px rgba(0,0,0,.08);

    position: fixed;
    z-index: 9999;
    top: 0;
    right: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    overflow-y: scroll;
}
.form-card.hide {
    display: none;
}
.input-group{
    margin-bottom:20px;
}

.input-group label{

    display:block;

    margin-bottom:8px;

    font-weight:600;

    color:#333;
}

.input-group input,
.input-group select{

    width:100%;

    padding:14px;

    border:1px solid #d8dce3;

    border-radius:10px;

    outline:none;

    font-size:1rem;

    background:#fff;
}

.input-group input:focus{

    border-color:#2563eb;
}

.time-wrapper{

    position:relative;
}

.time-wrapper i{

    position:absolute;

    right:15px;

    top:50%;

    transform:translateY(-50%);

    color:#777;
}

.save-btn{

    width:100%;

    border:none;

    background:#16a34a;

    color:white;

    padding:15px;

    border-radius:10px;

    font-size:1rem;

    font-weight:bold;

    cursor:pointer;

    margin-top:10px;

    transition:.3s;
}
.save-btn.exp {
    background: red;
}
.save-btn:hover{

    background:#12833b;
}

.save-btn i{
    margin-right:8px;
}
</style>
<link rel="stylesheet" href="/main.css" type="text/css"/>
<link rel="stylesheet" href="/nav.css" type="text/css"/>
</head>
<body onload="loadID('<%=idCarrier%>');">

<header class="top-bar">

    <button class="icon-btn" onclick="window.location.href='/account/records';">
        <i class="fa-solid fa-arrow-left"></i>
    </button>

    <h2>DAILY RECORD</h2>

    <button class="icon-btn">
        <i class="fa-regular fa-calendar"></i>
    </button>

</header>

<main>

    <!-- DATE NAVIGATION -->

    <div class="date-selector">

        <button>
            <i class="fa-solid fa-chevron-left"></i>
        </button>

        <div class="current-date">

            <i class="fa-regular fa-calendar"></i>

            <span><%= info.title %></span>

        </div>

        <button>
            <i class="fa-solid fa-chevron-right"></i>
        </button>

    </div>

    <!-- SALES -->

    <!-- SALES -->

<section class="record-card">

    <h3 class="sales-title">
        SALES
    </h3>
    <div class="record-lists">
    <!-- SALE 1 -->
     <% if (info.sales.length<=0) {%>
        <br/><br/>
        <div style="color: red; text-align: center;">
            No Sales Available
        </div>
        <center>
            <div style="border: none; padding: 2%; padding-left: 3%; padding-right: 3%; width: fit-content; background: green; color: white; text-align: center; border-radius: 15px; cursor: pointer;" onclick="showSale(true);">
                ADD SALE
            </div>
        </center>
<% } else { for (var i=0; i<info.sales.length; i++) {%>
        <div class="record-row">

        <div class="record-details">

            <h4><%= info.sales[i].name %></h4>
            <small>
                ID: <%= info.sales[i].id %>
            </small>
            <small>
                Quantity: <%= info.sales[i].qn %>
            </small>

            <small>
                Time: <%= info.sales[i].createdAt %>
            </small>

        </div>

        <span class="amount green">
            <%= info.sales[i].cost %>
        </span>
<div class="controls_">
    <div class="btn edit" onclick="editSale('<%= info.sales[i]._id %>');"><i class="fa-solid fa-pen"></i></div>
    <div class="btn delete" onclick="deleteSale('<%= info.sales[i]._id %>');"><i class="fa-solid fa-trash"></i></div>
</div>
    </div>

    <%} }%>
</div>
    <div class="total-row">

        <strong>
            Total Sales
        </strong>

        <strong class="green">
            <%= sale_total %>
        </strong>

    </div>

</section>


    <!-- EXPENSES -->

    <section class="record-card">

        <h3 class="expense-title">
            EXPENSES
        </h3>
        <div class="record-lists">
            <% if (info.expense.length<=0) {%>
                <br/><br/>
                <div style="color: green; text-align: center;">
            No Expense Available
        </div>
        <center>
            <div style="border: none; padding: 2%; padding-left: 3%; padding-right: 3%; width: fit-content; background: red; color: white; text-align: center; border-radius: 60px; cursor: pointer;" onclick="showExp(true);">
                ADD EXPENSE
            </div>
        </center>
            <%} else { for (var i=0; i<info.expense.length; i++) {%>
                <div class="record-row">
            <div>
                <h4><%= info.expense[i].title %></h4>
                <small><%= info.expense[i].createdAt %></small>
            </div>

            <span class="amount red">
                <%= info.expense[i].cost %>
            </span>
<div class="controls_">
    <div class="btn edit" onclick="editExp('<%= info.expense[i]._id %>');"><i class="fa-solid fa-pen"></i></div>
    <div class="btn delete" onclick="deleteExp('<%= info.expense[i]._id %>');"><i class="fa-solid fa-trash"></i></div>
</div>
        </div>
            <%}}%>
        
    </div>
        <div class="total-row">

            <strong>Total Expenses</strong>

            <strong class="red">
                <%= exp_total %>
            </strong>

        </div>

    </section>

    <!-- PROFIT -->

    <section class="profit-card">

        <span>NET</span>

        <strong>
            <%= net %>
        </strong>

    </section>

</main>


<!--

======>>>>FORMS AREA

-->
    <form class="form-card" id="sale-form" method="post">

        <div class="input-group">

            <label>
                Product Name
            </label>

            <select type="text" id="productsName" oninput="updateID();" name="name" required>
        </select>

        </div>

        <div class="input-group">

            <label>
                Product ID
            </label>

            <select type="text" id="productsID" oninput="updateTotal();" name="id" required>
        </select>

        </div>

        <div class="input-group">

            <label>
                Quantity
            </label>

            <input
            type="number"
            placeholder="e.g. 5" name="qn" id="qn" oninput="updateTotal();" required/>

        </div>

        <div class="input-group">

            <label>
                Total Price (TZS)
            </label>

            <input type="number"
            placeholder="e.g. 20000" id="total" name="total" required/>

        </div>

        <div class="input-group">

            <label>
                Time
            </label>

            <div class="time-wrapper">

                <input type="text" readonly=true id="clock" name="time" required/>

                <i class="fa-regular fa-clock"></i>

            </div>

        </div>

        <button class="save-btn">

            <i class="fa-solid fa-floppy-disk"></i>

            SAVE SALE

        </button>

        <button class="save-btn exp" type="reset" onclick="showSale(false);">

            <i class="fa-solid fa-close"></i>

            CLOSE

        </button>

    </form>

<!--
Expense form
-->
    <form class="form-card" id="exp-form" method="post">

        <div class="input-group">

            <label>
                Title
            </label>

            <input
            type="text"
            placeholder="e.g. Food" name="title" id="qn" required/>

        </div>

        <div class="input-group">

            <label>
                Total Price (TZS)
            </label>

            <input type="number"
            placeholder="e.g. 20000" name="cost" required/>

        </div>

        <div class="input-group">

            <label>
                Time
            </label>

            <div class="time-wrapper">

                <input type="text" readonly=true id="exp_clock" name="time" required/>

                <i class="fa-regular fa-clock"></i>

            </div>

        </div>

        <button class="save-btn exp">

            <i class="fa-solid fa-floppy-disk"></i>

            SAVE EXPENSE

        </button>

        <button class="save-btn exp" type="reset" onclick="showExp(false);">

            <i class="fa-solid fa-close"></i>

            CLOSE

        </button>

    </form>



<!--
=================>EDITING FORMS (SALES) AND (EXPENSE)    
-->
